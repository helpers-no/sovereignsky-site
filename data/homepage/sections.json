{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "SovereignSky Homepage",
  "description": "Digital sovereignty resources for Norwegian organizations",
  "abstract": "Homepage sections defining the content and layout of the SovereignSky homepage",
  "summary": "A JSON-driven homepage where content sections are defined in data and rendered by Hugo templates",
  "listConfig": {
    "sorting": {
      "field": "weight",
      "direction": "asc"
    },
    "display": {
      "renderMode": "sections"
    }
  },
  "itemListElement": [
    {
      "@type": "WebPageElement",
      "identifier": "hero",
      "name": "Hero Section",
      "sectionType": "hero",
      "weight": 10,
      "enabled": true,
      "config": {
        "style": "gradient",
        "gradient": "linear-gradient(135deg, #3b82f6 0%, #06b6d4 50%, #10b981 100%)",
        "image": null,
        "imagePosition": "right",
        "badge": {
          "text": "Open source",
          "subtext": "Sovereign infrastructure"
        },
        "title": "Born from crisis. Built for independence.",
        "description": "Working infrastructure, open-source tools, and the data you need to operate independently — with or without the cloud."
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "ready-to-use",
      "name": "Ready to Use Tools",
      "sectionType": "product-cards",
      "weight": 15,
      "enabled": true,
      "config": {
        "title": "Ready to use — start building today",
        "description": "We built these tools because they didn't exist when we needed them. Now they're ready for you.",
        "items": [
          {
            "title": "DevContainer Toolbox (DCT)",
            "subtitle": "One command. Full dev environment. Any project.",
            "description": "New developer productive in minutes, not days. Python, TypeScript, Go, C#, Java, Rust, and 20+ tools pre-configured. Works on Windows, Mac, and Linux.",
            "url": "/sovereignsky/devcontainer-toolbox/",
            "video": "/img/dct-hero.webm",
            "badge": "Live",
            "cta": "Get started"
          },
          {
            "title": "Urbalurba Infrastructure Stack (UIS)",
            "subtitle": "Complete datacenter on your laptop.",
            "description": "Kubernetes, databases, AI, monitoring, and 30+ open-source services. Pre-configured stacks ready to run. No cloud account needed.",
            "url": "/sovereignsky/urbalurba-infrastructure/",
            "video": "/img/uis-hero.webm",
            "badge": "Live",
            "cta": "Explore services"
          },
          {
            "title": "Dev Templates",
            "subtitle": "Start building in minutes.",
            "description": "Production-ready starters for APIs, web apps, and backends. Skip weeks of boilerplate. Best practices built in.",
            "image": "/sovereignsky/dev-templates/featured.png",
            "url": "/sovereignsky/dev-templates/",
            "badge": "Live",
            "cta": "Browse templates"
          },
          {
            "title": "Client Provisioning",
            "subtitle": "For ops teams managing machine fleets.",
            "description": "Automated Rancher Desktop deployment via Intune (Windows) and Jamf (macOS). For unmanaged machines, just download Rancher Desktop and install DCT directly.",
            "image": "/sovereignsky/client-provisioning/featured.png",
            "url": "/sovereignsky/client-provisioning/",
            "badge": "Live",
            "cta": "Learn more"
          }
        ]
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "databases",
      "name": "Databases Stats Grid",
      "sectionType": "stats-grid",
      "weight": 75,
      "enabled": true,
      "config": {
        "title": "The data behind digital sovereignty",
        "description": "We've mapped infrastructure, software, laws, and publications across multiple dimensions.",
        "columns": 4,
        "items": [
          {
            "id": "countries",
            "label": "Countries",
            "sublabel": "Jurisdictions analyzed",
            "url": "/countries/",
            "icon": "globe",
            "color": "#34d399",
            "countSource": "data.countries.countries.itemListElement"
          },
          {
            "id": "blocs",
            "label": "Regional Blocs",
            "sublabel": "Data governance frameworks",
            "url": "/blocs/",
            "icon": "building",
            "color": "#14b8a6",
            "countSource": "data.blocs.blocs.itemListElement"
          },
          {
            "id": "laws",
            "label": "Laws",
            "sublabel": "Legal frameworks documented",
            "url": "/laws/",
            "icon": "scale",
            "color": "#38bdf8",
            "countSource": "data.laws.laws.itemListElement"
          },
          {
            "id": "networks",
            "label": "Networks",
            "sublabel": "Submarine cables mapped",
            "url": "/networks/",
            "icon": "link",
            "color": "#f87171",
            "countSource": "data.networks.networks"
          },
          {
            "id": "publications",
            "label": "Publications",
            "sublabel": "Research papers indexed",
            "url": "/publications/",
            "icon": "book",
            "color": "#fbbf24",
            "countSource": "data.publications.publications"
          },
          {
            "id": "blog",
            "label": "Blog",
            "sublabel": "Articles and insights",
            "url": "/blog/",
            "icon": "newspaper",
            "color": "#a855f7",
            "countSource": "pages.blog"
          },
          {
            "id": "software",
            "label": "Software",
            "sublabel": "MVP products · 4,000+ being prepared",
            "url": "/software/",
            "icon": "code",
            "color": "#3b82f6",
            "countSource": "data.software.softwareList"
          },
          {
            "id": "datacenters",
            "label": "Datacenters",
            "sublabel": "Cloud regions worldwide",
            "url": "/datacenters/",
            "icon": "server",
            "color": "#f472b6",
            "countSource": "data.datacenters.datacenters.regions"
          },
          {
            "id": "projects",
            "label": "Projects",
            "sublabel": "Open-source tools",
            "url": "/sovereignsky/",
            "icon": "rocket",
            "color": "#22c55e",
            "countSource": "data.sovereignsky.projects.itemListElement"
          }
        ]
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "personas",
      "name": "Audience Personas",
      "sectionType": "audience-cards",
      "weight": 30,
      "enabled": false,
      "config": {
        "title": "What does digital sovereignty mean for you?",
        "description": "There's a lot to digest. We've curated the content for your role so you can get started quickly.",
        "source": {
          "type": "data",
          "path": "audience.audience.itemListElement"
        },
        "cardStyle": "icon-centered",
        "columns": 5
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "blog",
      "name": "Latest Blog Posts",
      "sectionType": "content-cards",
      "weight": 40,
      "enabled": true,
      "config": {
        "title": "Latest insights",
        "description": "Analysis, commentary, and news on digital sovereignty.",
        "background": "base-200",
        "source": {
          "type": "section",
          "path": "blog",
          "select": "explicit",
          "identifiers": [
            "2025-12-10-developer-power-sovereignty",
            "2025-12-11-digital-sovereignty-moral-independence",
            "2025-12-01-norway-exit-strategy"
          ]
        },
        "cardStyle": "vertical",
        "columns": 3,
        "footer": {
          "button": {
            "text": "View all articles",
            "url": "/blog/"
          }
        }
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "publications",
      "name": "Essential Publications",
      "sectionType": "content-cards",
      "weight": 50,
      "enabled": true,
      "config": {
        "title": "Essential reading",
        "description": "Key reports and frameworks shaping digital sovereignty policy.",
        "source": {
          "type": "section",
          "path": "publications",
          "select": "explicit",
          "identifiers": [
            "totalberedskapsmeldingen-2025",
            "ffi-frivillige-beredskapsorganisasjoner-totalforsvar",
            "safeguarding-humanitarian-digital-threats",
            "eu-cloud-sovereignty-framework"
          ]
        },
        "cardStyle": "compact",
        "columns": 2,
        "footer": {
          "button": {
            "text": "View all publications",
            "url": "/publications/"
          }
        }
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "laws",
      "name": "Key Legal Frameworks",
      "sectionType": "laws-list",
      "weight": 55,
      "enabled": true,
      "config": {
        "title": "Laws that affect your cloud data",
        "description": "If your organization uses cloud services, these laws determine who can access your data - and when.",
        "identifiers": [
          "gdpr",
          "cloud-act",
          "nis2",
          "dora"
        ],
        "groupByType": false,
        "columns": 2,
        "footer": {
          "text": "Want to understand how these laws affect you?",
          "button": {
            "text": "View all laws",
            "url": "/laws/"
          }
        }
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "events",
      "name": "Key Events",
      "sectionType": "events-list",
      "weight": 60,
      "enabled": false,
      "config": {
        "title": "Key Events in 2026",
        "description": "Conferences, exercises, and gatherings focused on digital sovereignty and preparedness.",
        "background": "base-200",
        "source": {
          "type": "query",
          "limit": 6,
          "sort": "date"
        },
        "footer": {
          "button": {
            "text": "Full calendar",
            "url": "/events/"
          }
        }
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "cta",
      "name": "Call to Action",
      "sectionType": "cta",
      "weight": 70,
      "enabled": true,
      "config": {
        "style": "gradient",
        "gradient": "linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%)",
        "title": "Help make Norway digitally sovereign",
        "description": "Born from the chaos of running Europe's largest refugee transit camp with no tools, SovereignSky is a sovereign cloud platform that ensures organizations can operate — with or without the cloud. Built by helpers.no. Open source. Open to everyone.",
        "features": [
          {
            "icon": "chart",
            "text": "Contribute research"
          },
          {
            "icon": "lightbulb",
            "text": "Suggest improvements"
          },
          {
            "icon": "megaphone",
            "text": "Share with your network"
          },
          {
            "icon": "chat",
            "text": "Join the conversation"
          }
        ],
        "buttons": [
          {
            "text": "View on GitHub",
            "url": "https://github.com/helpers-no",
            "style": "primary",
            "icon": "github",
            "external": true
          },
          {
            "text": "About this initiative",
            "url": "/about/",
            "style": "outline"
          }
        ]
      }
    },
    {
      "@type": "WebPageElement",
      "identifier": "projects",
      "name": "Projects Roadmap",
      "sectionType": "projects-roadmap",
      "weight": 80,
      "enabled": true,
      "config": {
        "title": "What we're building",
        "description": "Projects in development to help organizations achieve digital sovereignty.",
        "background": "base-200",
        "items": [
          {
            "projectRef": "software-database",
            "description": "Tracking what France, Germany, Denmark, and other European governments recommend. 4,400+ products from government-vetted catalogs, mapped with sovereign alternatives.",
            "badge": "Coming Soon",
            "badgeStyle": "primary",
            "progress": 35,
            "progressLabel": "MVP Complete"
          },
          {
            "projectRef": "sovdev-logger",
            "description": "One log call — automatic logs, metrics, traces, and service maps. Works with Grafana, Azure Monitor, or any OpenTelemetry backend. TypeScript now, Go/Python/C#/Rust coming.",
            "badge": "Active",
            "badgeStyle": "primary",
            "progress": 60,
            "progressLabel": "TypeScript available"
          },
          {
            "projectRef": "ndsi",
            "badge": "In Development",
            "badgeStyle": "secondary",
            "progress": 15,
            "progressLabel": "Design Phase"
          }
        ],
        "footer": {
          "text": "Want to help build these tools?",
          "button": {
            "text": "See all projects",
            "url": "/sovereignsky/"
          }
        }
      }
    }
  ]
}